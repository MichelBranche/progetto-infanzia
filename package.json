{
  "name": "branchefy",
  "private": true,
  "version": "0.2.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node tools/dev-api.mjs",
    "dev:stop": "node tools/stop-dev.mjs",
    "dev:browser": "npm run dev:stop && concurrently -k -n api,vite -c blue,green \"npm run dev:api\" \"node tools/wait-dev-api.mjs && vite --port 5173 --strictPort\"",
    "catalog:export-seed": "cargo run --manifest-path src-tauri/Cargo.toml --bin export-sc-catalog-seed --release",
    "build:web": "npm run build --prefix web",
    "build:desktop": "tsc && vite build",
    "build": "npm run build --prefix web",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons": "tauri icon app-icon.png -o src-tauri/icons",
    "test-addon": "node tools/test-stream-addon.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@supabase/supabase-js": "^2.109.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "emoji-picker-react": "^4.19.1",
    "epubjs": "^0.3.93",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.21.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
