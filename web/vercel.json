{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci --prefix .. && npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/sc-image/:path*",
      "destination": "https://progetto-infanzia-production.up.railway.app/sc-image/:path*"
    },
    {
      "source": "/poster/:id",
      "destination": "https://progetto-infanzia-production.up.railway.app/poster/:id"
    },
    {
      "source": "/series-poster/:id",
      "destination": "https://progetto-infanzia-production.up.railway.app/series-poster/:id"
    },
    {
      "source": "/saturn-poster/:path*",
      "destination": "https://progetto-infanzia-production.up.railway.app/saturn-poster/:path*"
    },
    {
      "source": "/loonex-poster/:path*",
      "destination": "https://progetto-infanzia-production.up.railway.app/loonex-poster/:path*"
    },
    {
      "source": "/((?!api/|assets/|audio/|hub/|favicon|apple-touch|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
